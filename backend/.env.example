# ------------------------------------------------------------------
# WorkTrack backend environment
# Copy to .env and fill in values. NEVER commit the real .env file.
# ------------------------------------------------------------------

NODE_ENV=development
PORT=5000
API_VERSION=v1
APP_NAME=WorkTrack
# Frontend origin (used for email links)
APP_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

# MongoDB Atlas connection string (see docs/MONGODB_ATLAS_SETUP.md)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/worktrack?retryWrites=true&w=majority

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=GENERATE_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=GENERATE_ANOTHER_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS
JWT_REFRESH_EXPIRES_IN=30d
COOKIE_SECRET=GENERATE_ANOTHER_LONG_RANDOM_SECRET

# Comma-separated allowlist of frontend origins
CORS_ORIGINS=http://localhost:5173

# Cloudinary (see docs/CLOUDINARY_SETUP.md). Uploads are disabled until configured.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=worktrack

MAX_IMAGE_SIZE_MB=10
MAX_VIDEO_SIZE_MB=100
MAX_DOCUMENT_SIZE_MB=25

# Optional Redis (rate limiting / caching / socket scaling)
REDIS_URL=

# Optional SMTP — when empty, emails are logged to the console instead
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=WorkTrack
SMTP_FROM_EMAIL=

LOG_LEVEL=debug
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=500
AUTH_RATE_LIMIT_MAX_REQUESTS=10
PASSWORD_RESET_EXPIRES_MINUTES=30
EMAIL_VERIFICATION_EXPIRES_HOURS=24
INVITATION_EXPIRES_DAYS=7
